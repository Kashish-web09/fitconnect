<link rel="stylesheet" href="/css/auth.css">
<form
action="/customerUser/signup"
method="POST"
enctype="multipart/form-data">

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">Name</label>

<input
class="form-control form-control-lg"
name="name"
>
                <% if(typeof errors!=="undefined" && errors.name){ %>
    <div class="invalid-feedback d-block">
        <%= errors.name.msg %>
    </div>
<%}%>


</div>

<div class="col-md-6 mb-3">

<label class="form-label">Phone</label>

<input
class="form-control form-control-lg"
name="phoneno"
>
                <% if(typeof errors!=="undefined" && errors.phoneno){ %>
    <div class="invalid-feedback d-block">
        <%= errors.phoneno.msg %>
    </div>
<%}%>

</div>

</div>

<div class="mb-3">

<label class="form-label">Email</label>

<input
type="email"
class="form-control form-control-lg"
name="email"
>
                <% if(typeof errors!=="undefined" && errors.email){ %>
    <div class="invalid-feedback d-block">
        <%= errors.email.msg %>
    </div>
<%}%>

</div>

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">Password</label>

<input
type="password"
class="form-control form-control-lg"
name="password"
>
                <% if(typeof errors!=="undefined" && errors.password){ %>
    <div class="invalid-feedback d-block">
        <%= errors.password.msg %>
    </div>
<%}%>

</div>

<div class="col-md-6 mb-3">

<label class="form-label">Confirm Password</label>

<input
type="password"
class="form-control form-control-lg"
name="confirmPass"
>
                <% if(typeof errors!=="undefined" && errors.confirmPass){ %>
    <div class="invalid-feedback d-block">
        <%= errors.confirmPass.msg %>
    </div>
<%}%>


</div>

</div>

<div class="mb-4">

<label class="form-label">Profile Image</label>

<input
type="file"
class="form-control form-control-lg"
name="image">

</div>

<button class="btn btn-primary btn-lg w-100">

Create Account

</button>

</form>

<div class="text-center mt-4">

Already have an account?

<a href="/customerUser/signin">

Login

</a>

</div>