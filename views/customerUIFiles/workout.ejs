<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-activity text-primary"></i>
                My Workout Tracker
            </h2>

            <p class="text-muted">
                Track your daily fitness journey
            </p>
        </div>

        <a href="/customer/workout/add" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle"></i>
            Add Workout
        </a>

    </div>

    <% 
        const total = workouts.length;
        const completed = workouts.filter(w => w.completed).length;
        const pending = total - completed;
        const progress = total ? Math.round((completed/total)*100) : 0;
    %>

    <!-- Progress -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <div class="d-flex justify-content-between mb-2">

                <h5 class="fw-bold mb-0">
                    Today's Progress
                </h5>

                <span class="fw-bold text-primary">
                    <%= progress %>%
                </span>

            </div>

            <div class="progress" style="height:12px">

                <div class="progress-bar"
                    style="width: <%= progress %>%">
                </div>

            </div>

        </div>

    </div>



    <!-- Stats -->

    <div class="row mb-4">

        <div class="col-md-3 mb-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <h3 class="fw-bold">
                        <%= total %>
                    </h3>

                    <small class="text-muted">
                        Total Workouts
                    </small>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <h3 class="text-success fw-bold">
                        <%= completed %>
                    </h3>

                    <small class="text-muted">
                        Completed
                    </small>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <h3 class="text-warning fw-bold">
                        <%= pending %>
                    </h3>

                    <small class="text-muted">
                        Pending
                    </small>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-3">

            <div class="card border-0 shadow-sm text-center">

                <div class="card-body">

                    <h3 class="text-primary fw-bold">
                        <%= progress %>%
                    </h3>

                    <small class="text-muted">
                        Completion
                    </small>

                </div>

            </div>

        </div>

    </div>



    <!-- Search -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <form class="row g-3">

                <div class="col-md-5">

                    <input
                        class="form-control"
                        placeholder="Search exercise...">

                </div>

                <div class="col-md-3">

                    <select class="form-select">

                        <option>All Days</option>

                        <option>Monday</option>
                        <option>Tuesday</option>
                        <option>Wednesday</option>
                        <option>Thursday</option>
                        <option>Friday</option>
                        <option>Saturday</option>
                        <option>Sunday</option>

                    </select>

                </div>

                <div class="col-md-2">

                    <select class="form-select">

                        <option>All Status</option>

                        <option>Completed</option>
                        <option>Pending</option>

                    </select>

                </div>

                <div class="col-md-2">

                    <button class="btn btn-primary w-100">

                        Search

                    </button>

                </div>

            </form>

        </div>

    </div>



    <% if(workouts.length){ %>

    <div class="row">

        <% workouts.forEach(workout=>{ %>

        <div class="col-lg-6 mb-4">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <h4 class="fw-bold">
                                <%= workout.exerciseName %>
                            </h4>

                            <div class="text-muted">
                                <%= workout.muscleGroup %> • <%= workout.day %>
                            </div>

                        </div>

                        <div>

                            <% if(workout.completed){ %>

                            <span class="badge bg-success">
                                Completed
                            </span>

                            <% }else{ %>

                            <span class="badge bg-warning text-dark">
                                Pending
                            </span>

                            <% } %>

                        </div>

                    </div>

                    <div class="row text-center mt-4">

                        <div class="col">

                            <h5><%= workout.sets %></h5>

                            <small class="text-muted">
                                Sets
                            </small>

                        </div>

                        <div class="col">

                            <h5><%= workout.reps %></h5>

                            <small class="text-muted">
                                Reps
                            </small>

                        </div>

                        <div class="col">

                            <h5><%= workout.weight %> Kg</h5>

                            <small class="text-muted">
                                Weight
                            </small>

                        </div>

                        <div class="col">

                            <h5><%= workout.duration %></h5>

                            <small class="text-muted">
                                Min
                            </small>

                        </div>

                    </div>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <div>

                            <% if(!workout.completed){ %>

                            <a href="/customer/workout/complete/<%= workout._id %>"
                                class="btn btn-success btn-sm">

                                <i class="bi bi-check-circle"></i>

                                Complete

                            </a>

                            <% } %>

                        </div>

                        <div>

                            <a href="/customer/workout/edit/<%= workout._id %>"
                                class="btn btn-outline-primary btn-sm">

                                Edit

                            </a>

                            <a href="/customer/workout/delete/<%= workout._id %>"
                                class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Are you sure you want to delete this workout')" 
                                >

                                Delete

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <% } else { %>

    <div class="text-center py-5">

        <i class="bi bi-emoji-frown display-2 text-secondary"></i>

        <h3 class="mt-3">
            No Workouts Yet
        </h3>

        <p class="text-muted">
            Add your first workout and start tracking your fitness journey.
        </p>

        <a href="/customer/workout/add" class="btn btn-primary">
            Add Workout
        </a>

    </div>

    <% } %>

</div>